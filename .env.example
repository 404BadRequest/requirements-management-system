# Copiar a `.env.local` y completar según entorno.

# Selección de proveedores (valores: mock | supabase | postgres) y (supabase | authjs).
DATA_PROVIDER=postgres
AUTH_PROVIDER=authjs

# Auth.js (requerido si AUTH_PROVIDER=authjs). Generar con: `openssl rand -base64 32`.
AUTH_SECRET=

# Supabase (opcional). Si faltan URL y anon key, la app corre en modo local con datos mock.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# `true` para leer/escribir datos en Postgres vía adaptador Supabase (requiere migraciones aplicadas).
# Compatibilidad retro: si DATA_PROVIDER no está definido y este valor es `true`, se usa Supabase.
USE_SUPABASE_DATA=false

# Postgres portable (Neon u otro proveedor) cuando DATA_PROVIDER=postgres.
POSTGRES_URL=
# Recomendado: verify-full (evita warnings de pg-connection-string y mantiene seguridad fuerte TLS).
POSTGRES_SSL_MODE=verify-full
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_STATEMENT_TIMEOUT_MS=15000

# Con Supabase configurado: `false` desactiva el middleware de login (útil para E2E locales).
NEXT_PUBLIC_AUTH_ENABLED=true

# Rol simulado en modo local / cuando el middleware de auth está desactivado (Admin | Project Manager | Contributor | Viewer).
DEV_APP_ROLE=
